pico-8 cartridge // http://www.pico-8.com
version 42
__lua__
printh("RESULT sub_neg1_5 "..sub("hello",-1.5))
printh("RESULT sub_neg0_5 "..sub("hello",-0.5))
printh("RESULT sub_1_5 "..sub("hello",1.5))
printh("RESULT chr_neg0_5 "..ord(chr(-0.5)))
printh("RESULT chr_neg1_5 "..ord(chr(-1.5)))
poke(0x6000,0)
mset(0,0,5)
printh("RESULT mget_negx "..mget(-0.5,0))
printh("RESULT mget_0_5 "..mget(0.5,0))
fset(0,7,true)
printh("RESULT fget_negn "..(fget(-0.5) and "t" or "f"))
printh("RESULT fget_0_5 "..(fget(0.5) and "t" or "f"))
poke(0,0)
poke(0,-0.5)
printh("RESULT poke_negfrac "..peek(0))
poke(1,255.9)
printh("RESULT poke_frac_up "..peek(1))
memset(0x100,7,4)
printh("RESULT memset_val "..peek(0x100))
memset(0x104,-0.5,4)
printh("RESULT memset_val_neg "..peek(0x104))
cls()
sset(0,0,8)
spr(0,-0.5,0)
printh("RESULT spr_pixel_x0 "..pget(0,0))
printh("RESULT spr_pixel_xneg1 "..pget(-1,0))
printh("DONE")
