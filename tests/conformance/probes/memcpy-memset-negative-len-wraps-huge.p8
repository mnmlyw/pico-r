memcpy(0x1000,0,-1)
printh("RESULT memcpy_neglen "..peek(0x1000))
memset(0x1000,0,32)
poke(0,9)
memset(0x1000,7,-1)
printh("RESULT memset_neglen "..peek(0x1000))
memset(0x1000,0,32)
poke(0,9)
memcpy(0x1000,0,0)
printh("RESULT memcpy_zerolen "..peek(0x1000))
memset(0x1000,0,32)
poke(0,9)
memset(0x1000,7,0)
printh("RESULT memset_zerolen "..peek(0x1000))
